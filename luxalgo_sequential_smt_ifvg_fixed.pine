// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
//@version=6
indicator("Sequential SMT -> iFVG Signal [LuxAlgo]", shorttitle="SMTiFVG", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// --- Constants ---
COLOR_BULL = #089981
COLOR_BEAR = #f23645

// --- Types ---
type Pivot
    int index
    float price
    bool isHigh

type SMTEvent
    int id
    bool isBearish
    int startBar
    int expiryBar
    string pair
    float p1_price
    float p2_price

type FVGEvent
    int id
    int smtId
    float top
    float bottom
    bool isBullish
    int startBar
    box visualBox

// --- Inputs ---
grp_smt = "1. SMT (Directional Bias)"
smtMemory = input.int(20, "SMT Memory (Bars)", minval=5, group=grp_smt, tooltip="How long an SMT stays active as a filter for FVGs.")
pivotLookback = input.int(3, "Pivot Lookback", minval=1, group=grp_smt)
pivotTolerance = input.int(2, "Pivot Bar Tolerance", minval=0, group=grp_smt, tooltip="Max bar difference allowed between chart pivot and comparison pivot.")
useNQ = input.bool(true, "Compare ES/NQ", group=grp_smt)
useYM = input.bool(true, "Compare ES/YM", group=grp_smt)
nqSym = input.symbol("CME_MINI:NQ1!", "NQ Symbol", group=grp_smt)
ymSym = input.symbol("CBOT_MINI:YM1!", "YM Symbol", group=grp_smt)

grp_ifvg = "2. iFVG (Execution Trigger)"
rrRatio = input.float(2.0, "Risk/Reward Ratio", minval=0.1, group=grp_ifvg)
slOffset = input.float(1.5, "SL Offset (Ticks)", minval=0, group=grp_ifvg, tooltip="Buffer for SL placement outside the iFVG/Pivot.")

grp_debug = "Debug Toggles"
showPivots = input.bool(false, "Show Pivots", group=grp_debug)
showSmtMarkers = input.bool(true, "Show SMT Events", group=grp_debug)
showPendingFvg = input.bool(true, "Show Pending Linked FVGs", group=grp_debug)

// --- Global State ---
var activeSmts = array.new<SMTEvent>()
var pendingFvgs = array.new<FVGEvent>()

var chartHighs = array.new<Pivot>()
var chartLows = array.new<Pivot>()
var nqHighs = array.new<Pivot>()
var nqLows = array.new<Pivot>()
var ymHighs = array.new<Pivot>()
var ymLows = array.new<Pivot>()

// --- Functions ---
method updatePivots(array<Pivot> pivots, float price, bool isHigh) =>
    if not na(price)
        array.unshift(pivots, Pivot.new(bar_index[pivotLookback], price, isHigh))
        if array.size(pivots) > 50
            array.pop(pivots)

get_ohl() =>
    [high, low, close]

findMatchingPivot(array<Pivot> compPivots, int targetIndex, int tolerance) =>
    Pivot result = na
    if array.size(compPivots) > 0
        for i = 0 to array.size(compPivots) - 1
            Pivot p = array.get(compPivots, i)
            if math.abs(p.index - targetIndex) <= tolerance
                result := p
                break
    result

// --- Core Data ---
[nqH, nqL, nqC] = request.security(nqSym, timeframe.period, get_ohl())
[ymH, ymL, ymC] = request.security(ymSym, timeframe.period, get_ohl())

// Detect Chart Pivots
ph = ta.pivothigh(pivotLookback, pivotLookback)
pl = ta.pivotlow(pivotLookback, pivotLookback)
chartHighs.updatePivots(ph, true)
chartLows.updatePivots(pl, false)

// Detect Comparison Pivots
nqPH = ta.pivothigh(nqH, pivotLookback, pivotLookback)
nqPL = ta.pivotlow(nqL, pivotLookback, pivotLookback)
nqHighs.updatePivots(nqPH, true)
nqLows.updatePivots(nqPL, false)

ymPH = ta.pivothigh(ymH, pivotLookback, pivotLookback)
ymPL = ta.pivotlow(ymL, pivotLookback, pivotLookback)
ymHighs.updatePivots(ymPH, true)
ymLows.updatePivots(ymPL, false)

// --- SMT Logic ---
processSmt(array<Pivot> cPivots, array<Pivot> sPivots, string pair) =>
    if array.size(cPivots) >= 2
        Pivot c2 = array.get(cPivots, 0)
        Pivot c1 = array.get(cPivots, 1)

        Pivot s2 = findMatchingPivot(sPivots, c2.index, pivotTolerance)
        Pivot s1 = findMatchingPivot(sPivots, c1.index, pivotTolerance)

        if not na(s2) and not na(s1)
            bool isBearish = c1.isHigh
            bool isSmt = false

            if isBearish
                isSmt := (c2.price > c1.price and s2.price < s1.price) or (c2.price < c1.price and s2.price > s1.price)
            else
                isSmt := (c2.price < c1.price and s2.price > s1.price) or (c2.price > c1.price and s2.price < s1.price)

            if isSmt
                bool exists = false
                if array.size(activeSmts) > 0
                    for i = 0 to array.size(activeSmts) - 1
                        if array.get(activeSmts, i).id == c2.index
                            exists := true
                            break
                if not exists
                    array.unshift(activeSmts, SMTEvent.new(c2.index, isBearish, bar_index, bar_index + smtMemory, pair, c1.price, c2.price))
                    if showSmtMarkers
                        label.new(c2.index, c2.price, (isBearish ? "▼ Bear SMT\n" : "▲ Bull SMT\n") + pair, color=isBearish ? COLOR_BEAR : COLOR_BULL, textcolor=color.white, style=isBearish ? label.style_label_down : label.style_label_up, size=size.tiny)

if not na(ph)
    if useNQ
        processSmt(chartHighs, nqHighs, "ES/NQ")
    if useYM
        processSmt(chartHighs, ymHighs, "ES/YM")
if not na(pl)
    if useNQ
        processSmt(chartLows, nqLows, "ES/NQ")
    if useYM
        processSmt(chartLows, ymLows, "ES/YM")

// --- Cleanup Expired SMTs ---
int sIdx = 0
while sIdx < array.size(activeSmts)
    if bar_index > array.get(activeSmts, sIdx).expiryBar
        array.remove(activeSmts, sIdx)
    else
        sIdx += 1

// --- FVG Detection & SMT Linking ---
bool isBullishFvg = high[2] < low and close[1] > open[1]
bool isBearishFvg = low[2] > high and close[1] < open[1]

if (isBullishFvg or isBearishFvg) and array.size(activeSmts) > 0
    for i = 0 to array.size(activeSmts) - 1
        SMTEvent s = array.get(activeSmts, i)
        if s.isBearish and isBullishFvg
            box b = showPendingFvg ? box.new(bar_index[2], low, bar_index, high[2], bgcolor=color.new(COLOR_BEAR, 90), border_color=na) : na
            array.unshift(pendingFvgs, FVGEvent.new(bar_index, s.id, high[2], low, true, bar_index, b))
            break
        if not s.isBearish and isBearishFvg
            box b = showPendingFvg ? box.new(bar_index[2], low[2], bar_index, high, bgcolor=color.new(COLOR_BULL, 90), border_color=na) : na
            array.unshift(pendingFvgs, FVGEvent.new(bar_index, s.id, low[2], high, false, bar_index, b))
            break

// --- Inversion Trigger & Signal Generation ---
int fIdx = 0
while fIdx < array.size(pendingFvgs)
    FVGEvent f = array.get(pendingFvgs, fIdx)
    bool smtStillActive = false
    SMTEvent parentSmt = na

    if array.size(activeSmts) > 0
        for j = 0 to array.size(activeSmts) - 1
            SMTEvent candidate = array.get(activeSmts, j)
            if candidate.id == f.smtId
                smtStillActive := true
                parentSmt := candidate
                break

    bool invalidated = not smtStillActive or bar_index - f.startBar > 50
    bool trigger = false

    if not invalidated
        if f.isBullish and close < f.bottom
            trigger := true
        else if not f.isBullish and close > f.top
            trigger := true

    if trigger
        bool isBuy = not f.isBullish
        color sigColor = isBuy ? COLOR_BULL : COLOR_BEAR
        box.new(f.startBar, f.top, bar_index, f.bottom, bgcolor=color.new(sigColor, 70), border_color=sigColor)
        label.new(bar_index, isBuy ? low : high, isBuy ? "BUY" : "SELL", color=sigColor, textcolor=color.white, style=isBuy ? label.style_label_up : label.style_label_down, size=size.small)

        float entry = close
        float sl = isBuy ? f.bottom - (syminfo.mintick * slOffset) : f.top + (syminfo.mintick * slOffset)
        float risk = math.abs(entry - sl)
        float tp = isBuy ? entry + (risk * rrRatio) : entry - (risk * rrRatio)

        box.new(bar_index, entry, bar_index + 10, tp, bgcolor=color.new(COLOR_BULL, 80), border_color=COLOR_BULL)
        box.new(bar_index, entry, bar_index + 10, sl, bgcolor=color.new(COLOR_BEAR, 80), border_color=COLOR_BEAR)

        if not na(f.visualBox)
            box.delete(f.visualBox)
        array.remove(pendingFvgs, fIdx)
    else if invalidated
        if not na(f.visualBox)
            box.delete(f.visualBox)
        array.remove(pendingFvgs, fIdx)
    else
        if not na(f.visualBox)
            box.set_right(f.visualBox, bar_index)
        fIdx += 1

plotshape(showPivots ? ph : na, "Pivot High", shape.xcross, location.abovebar, color=color.gray, size=size.tiny, offset=-pivotLookback)
plotshape(showPivots ? pl : na, "Pivot Low", shape.xcross, location.belowbar, color=color.gray, size=size.tiny, offset=-pivotLookback)

alertcondition(false, "Setup Alert", "Strict SMT -> iFVG sequence completed.")
